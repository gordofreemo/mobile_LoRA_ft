# User-LoRA Round 5 — LaMP-3 multi-user training (K=100 parallel GPU procs).
#
# Each proc reads a per-user OPPU config from train/config/ (generated by
# data/lamp_user_stats/round5_gen_configs.py from the Step-6 template) and
# trains a fresh r=8 q+v-only LoRA on top of A1-lamp ckpt-1000 (stacked via
# train.py's base_adapter plumbing — NOT merged, per the plan's stack-vs-merge
# decision §"Design recap" row 9).
#
# OPPU recipe (pinned, do NOT edit):
#   r=8, lora_alpha=16, target_modules=[q_proj, v_proj], lora_dropout=0.05
#   LR=1e-5, weight_decay=1e-2, 3 epochs, cosine + 3% warmup
#   per_device_batch=4, grad_accum=2 (effective_bs=8 — OPPU's reported 3-16 range)
#   max_seq_length=7168 (T3-pinned from Step 5; data/lamp_user_stats/LaMP_3_round5_t3_sizing.json)
#
# Acceptance per user (Round-5 plan §Step 7):
#   - train/checkpoints/user_lora_lamp3_<user>_seed0/final/adapter_config.json
#     with r=8, target_modules=["q_proj", "v_proj"]
#   - train_meta.json with git_dirty=false, base_adapter_path ending in
#     a1_lamp_1ep_seed0/checkpoint-1000
#   - non-NaN final loss, below first loss
#   - All 100 adapters present (or at least 95)
#
# Wall-time estimate per proc:
#   - Most users (psize ~615, p95 seq_len 1510): ~5-10 min
#   - Outlier user u00010474 (single example at 6934 tokens): one slow batch
#     dominates; expect ~15-20 min for that proc.
#   Total: bounded by slot availability; with ~10 parallel slots, ~2-3 h wall time.
#
# Memory: bf16 + gradient_checkpointing + SDPA attention. At seq=7168, bs=4,
# fits comfortably in a 32 GB A100. If any proc OOMs (unlikely): bisect to
# per_device_batch=2 + grad_accum=4 in the offending user's config; surface
# the deviation to the user before retrying.
#
# Pre-reg plan: experiments/2026-06-18-user-lora-round5-lamp3-plan.md.
#
# Submit (after committing this file):
#   condor_submit condor/train_user_lora_lamp3.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = train/train.py
arguments             = --config $(config_path)

output                = /home/ange00008/projects/mobileFT_distill/runlogs/train_user_lora_lamp3.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/train_user_lora_lamp3.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/train_user_lora_lamp3.$(ClusterId).log

should_transfer_files = YES
environment           = "PROJECT_ROOT=/home/ange00008/projects/mobileFT_distill CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

# Same GPU class as the existing user-LoRA training subs.
gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0

max_job_retirement_time = 28800

stream_output           = true
stream_error            = true
when_to_transfer_output = ON_EXIT_OR_EVICT

request_GPUs          = 1
request_CPUs          = 4
request_memory        = 32G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

