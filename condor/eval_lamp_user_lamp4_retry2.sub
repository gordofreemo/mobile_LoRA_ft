# LaMP eval — Round 6 retry #2 for the 4 rows that failed in
# condor/eval_lamp_user_lamp4_retry1.sub (cluster 170373, procs 1/2/4/6).
#
# Different failure mode from retry1's "device busy" flake: these 4 landed
# on host `fornjoter` and died with "RuntimeError: CUDA error: no kernel
# image is available for execution on the device" inside
# peft/tuners/tuners_utils.py's cast_adapter_dtype. This is the documented
# Blackwell (sm_120) incompatibility from CLAUDE.md's "GPU capability
# ceiling" section — the ver4 Docker image's PyTorch (2.5.1+cu124) doesn't
# have kernels past sm_90, and `fornjoter` is apparently a Blackwell node.
# condor/eval_lamp_llama.sub already carries the `require_gpus` capability-
# range guard for exactly this; the LaMP-4 subs didn't yet (per CLAUDE.md:
# "harden them if they start failing the same way" — this is that). Added
# the same guard here AND retroactively to
# condor/{train,eval}_lamp_user_lamp4_{multi,retry1,smoke}.sub so future
# resubmits of any of those don't hit it again.
#
# Verified no partial output for these 4 rows (the only matching results/
# files on disk are for the OTHER condition of the same user, which
# succeeded earlier — not stale output from these failed rows).
#
# Submit (after committing this file):
#   condor_submit condor/eval_lamp_user_lamp4_retry2.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/eval_lamp.py

adapter      = none
base_adapter = none
user_fp      = u00000000

arguments    = --task LaMP_4 --split test --k 4 --seed 0 --adapter $(adapter) --base-adapter $(base_adapter) --user-records $(user_fp)

output                = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry2.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry2.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry2.$(ClusterId).log

should_transfer_files = YES
environment           = "MODEL_OUT_DIR=/home/ange00008/projects/mobileFT_distill/data/models/SmolLM3-3B LAMP_DIR=/home/ange00008/projects/mobileFT_distill/data/lamp_time CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0
# Capability *range*, not just a floor. The cluster has RTX PRO 6000 Blackwell
# (sm_120 / Capability=12.0) nodes that the ver4 Docker image's PyTorch
# (2.5.1+cu124) cannot target -- its kernels stop at sm_90. A bare
# gpus_minimum_capability = 8.0 admits Blackwell and the job dies at the
# first CUDA call with "no kernel image is available for execution on the
# device" (hit for the first time in this project on 2026-07-07, eval
# cluster 170373 procs 1/2/4/6, host fornjoter). Cap at < 10.0 to exclude
# Blackwell while keeping Hopper (9.0), Ada (8.9), and Ampere (8.0+). Pattern
# copied from condor/eval_lamp_llama.sub, which hit this first.
require_gpus            = Capability >= 8.0 && Capability < 10.0

request_GPUs          = 1
request_CPUs          = 2
request_memory        = 16G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

# 4 (adapter, base_adapter, user_fp) rows that failed with "no kernel image
# is available" (Blackwell) in cluster 170373 (1 C2 + 3 C3).
queue adapter, base_adapter, user_fp from (
  /home/ange00008/projects/mobileFT_distill/train/checkpoints/a1_lamp_1ep_seed0/checkpoint-1000, none, u00003333
  /home/ange00008/projects/mobileFT_distill/train/checkpoints/user_lora_lamp4_u00000076_oppu_seed0/final, /home/ange00008/projects/mobileFT_distill/train/checkpoints/a1_lamp_1ep_seed0/checkpoint-1000, u00000076
  /home/ange00008/projects/mobileFT_distill/train/checkpoints/user_lora_lamp4_u00000673_oppu_seed0/final, /home/ange00008/projects/mobileFT_distill/train/checkpoints/a1_lamp_1ep_seed0/checkpoint-1000, u00000673
  /home/ange00008/projects/mobileFT_distill/train/checkpoints/user_lora_lamp4_u00000554_oppu_seed0/final, /home/ange00008/projects/mobileFT_distill/train/checkpoints/a1_lamp_1ep_seed0/checkpoint-1000, u00000554
)
