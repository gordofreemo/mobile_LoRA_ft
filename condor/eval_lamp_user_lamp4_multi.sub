# LaMP eval — User-LoRA Round 6, 100 users x {C2, C3} on the LaMP-4 time-split.
#
# 200 parallel GPU procs:
#
#   C2 (A1-lamp + BM25, single Task-LoRA only):
#       adapter      = a1_lamp_1ep_seed0/checkpoint-1000
#       base_adapter = none
#       Reproduces the per-user baseline on each user's LaMP_4 test records.
#
#   C3 (A1-lamp + User-LoRA + BM25, stacked):
#       adapter      = user_lora_lamp4_<user>_oppu_seed0/final  (Round 6 Step 7 output)
#       base_adapter = a1_lamp_1ep_seed0/checkpoint-1000
#       Plan's stack-vs-merge decision, item #7: stack, not merge.
#
# Both conditions use --user-records <fp> to pin eval to that user's LaMP_4
# test records (1-25 per user, per data/lamp_user_stats/LaMP_4_user_records.json
# — unlike R5's LaMP-3 pool, which was ~1 test record/user).
#
# eval_lamp.py refuses to overwrite by default, so re-submits after partial
# sweeps only re-run the missing combinations.
#
# Plan reference: experiments/2026-06-19-user-lora-round6-lamp4-multi-plan.md §Step 9.
# See condor/eval_lamp_user_lamp3.sub (Round 5) for the multi-row queue-block
# pattern this generalizes.
#
# Submit (after committing this file):
#   condor_submit condor/eval_lamp_user_lamp4_multi.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/eval_lamp.py

# Macros driven by the queue block. eval_lamp.py treats "none" as "no adapter".
adapter      = none
base_adapter = none
user_fp      = u00000000

arguments    = --task LaMP_4 --split test --k 4 --seed 0 --adapter $(adapter) --base-adapter $(base_adapter) --user-records $(user_fp)

output                = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_multi.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_multi.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_multi.$(ClusterId).log

should_transfer_files = YES
# LAMP_DIR points at the TIME-BASED split (data/lamp_time/) per the
# Round-1 scaffolding-bug lesson. The --user-records IDs come from
# data/lamp_user_stats/LaMP_4_user_records.json which was built against
# the time-based split.
environment           = "MODEL_OUT_DIR=/home/ange00008/projects/mobileFT_distill/data/models/SmolLM3-3B LAMP_DIR=/home/ange00008/projects/mobileFT_distill/data/lamp_time CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

# Avoid the 16 GB V100 (loki) per the project-wide GPU filter.
gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0
# Capability *range*, not just a floor. The cluster has RTX PRO 6000 Blackwell
# (sm_120 / Capability=12.0) nodes that the ver4 Docker image's PyTorch
# (2.5.1+cu124) cannot target -- its kernels stop at sm_90. A bare
# gpus_minimum_capability = 8.0 admits Blackwell and the job dies at the
# first CUDA call with "no kernel image is available for execution on the
# device" (hit for the first time in this project on 2026-07-07, eval
# cluster 170373 procs 1/2/4/6, host fornjoter). Cap at < 10.0 to exclude
# Blackwell while keeping Hopper (9.0), Ada (8.9), and Ampere (8.0+). Pattern
# copied from condor/eval_lamp_llama.sub, which hit this first.
require_gpus            = Capability >= 8.0 && Capability < 10.0

request_GPUs          = 1
request_CPUs          = 2
request_memory        = 16G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

# 200 (adapter, base_adapter, user_fp) rows: 100 C2 (A1-lamp alone) then 100
# C3 (User-LoRA stacked over A1-lamp). Ordered to match the canonical
# top-100 user ordering from data/lamp_user_stats/LaMP_4_top100_users.json
# (Step-2 output). Absolute paths required (Round-1 scaffolding-bug lesson).
#
# Note on the first submission's training run (cluster 170332): 46/100 procs
# hit a transient CUDA "device busy" error from GPU-slot oversubscription on
# one execute node (tyr1), unrelated to eval — retried cleanly on a second
# submission (cluster 170343... see condor/train_user_lora_lamp4_retry1.sub).
# If this eval sweep sees a similar cluster of failures on one hostname,
# that's the same class of infra flake — retry just the failed rows rather
# than treating it as a pipeline bug.
