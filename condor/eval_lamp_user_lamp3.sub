# LaMP eval — User-LoRA Round 5, 100 users x {C2, C3} on the LaMP-3 time-split.
#
# 200 parallel GPU procs:
#
#   C2 (A1-lamp + BM25, single Task-LoRA only):
#       adapter      = a1_lamp_1ep_seed0/checkpoint-1000
#       base_adapter = none
#       Reproduces the per-user baseline on each user's 1 LaMP_3 test record.
#
#   C3 (A1-lamp + User-LoRA + BM25, stacked):
#       adapter      = user_lora_lamp3_<user>_seed0/final  (Round 5 Step 7 output)
#       base_adapter = a1_lamp_1ep_seed0/checkpoint-1000
#       Plan's stack-vs-merge decision row 9: stack, not merge.
#
# Both conditions use --user-records <fp> to pin eval to that user's single
# test record from data/lamp_user_stats/LaMP_3_user_records.json.
#
# eval_lamp.py refuses to overwrite by default, so re-submits after partial
# sweeps only re-run the missing combinations.
#
# Plan reference: experiments/2026-06-18-user-lora-round5-lamp3-plan.md §Step 8.
# See condor/eval_lamp_user.sub (Round 1) and eval_lamp_user_bm25k4.sub
# (Round 2-B) for the multi-row queue-block patterns this generalizes.
#
# Submit (after committing this file):
#   condor_submit condor/eval_lamp_user_lamp3.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/eval_lamp.py

# Macros driven by the queue block. eval_lamp.py treats "none" as "no adapter".
adapter      = none
base_adapter = none
user_fp      = u00000000

arguments    = --task LaMP_3 --split test --k 4 --seed 0 --adapter $(adapter) --base-adapter $(base_adapter) --user-records $(user_fp)

output                = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3.$(ClusterId).log

should_transfer_files = YES
# LAMP_DIR points at the TIME-BASED split (data/lamp_time/) per the
# Round-1 scaffolding-bug lesson. The --user-records IDs come from
# data/lamp_user_stats/LaMP_3_user_records.json which was built against
# the time-based split.
environment           = "MODEL_OUT_DIR=/home/ange00008/projects/mobileFT_distill/data/models/SmolLM3-3B LAMP_DIR=/home/ange00008/projects/mobileFT_distill/data/lamp_time CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

# Avoid the 16 GB V100 (loki) per the project-wide GPU filter.
gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0

request_GPUs          = 1
request_CPUs          = 2
request_memory        = 16G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

# 200 (adapter, base_adapter, user_fp) rows: 100 C2 (A1-lamp alone) then 100
# C3 (User-LoRA stacked over A1-lamp). Ordered to match the canonical
# top-100 user ordering from data/lamp_user_stats/LaMP_3_top100_users.json
# (Step-3 output). Absolute paths required (see condor/eval_lamp_user.sub
# header for the eval_lamp.py / PeftModel relative-path failure mode).
queue adapter, base_adapter, user_fp from (
