# LaMP eval — Round 5 (LaMP-3 multi-user) SMOKE — C3 / test on u00010694, --limit 5.
#
# One job. Exercises the maximum plumbing path for the R5 sweep:
#   base + A1-lamp + User-LoRA-R5 stacked + BM25 + --user-records on LaMP_3 test.
# Output filename gets a `_limit5` suffix so it cannot collide with the full
# R5 run's outputs (eval_lamp.py:503-505).
#
# u00010694 chosen because (a) it's the Step-7 training smoke target so we know
# the adapter is well-formed, and (b) it has the second-largest per-user max
# token length (5893) — surfaces any seq-length issue early. The split=test
# matches the full run; --limit 5 caps the LaMP_3 test load to 5 examples
# before the --user-records filter, which then reduces to 1 (u00010694's
# single test record).
#
# Plan reference: experiments/2026-06-18-user-lora-round5-lamp3-plan.md §Step 8.
#
# Submit:
#   condor_submit condor/eval_lamp_user_lamp3_smoke.sub
#
# After passing acceptance (1/1 filter on test, well-formed predictions,
# adapter_params shows both Task-LoRA + User-LoRA loaded), submit the full
# sweep: condor_submit condor/eval_lamp_user_lamp3.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/eval_lamp.py

arguments    = --task LaMP_3 --split test --k 4 --seed 0 --adapter /home/ange00008/projects/mobileFT_distill/train/checkpoints/user_lora_lamp3_u00010694_seed0/final --base-adapter /home/ange00008/projects/mobileFT_distill/train/checkpoints/a1_lamp_1ep_seed0/checkpoint-1000 --user-records u00010694 --limit 5

output                = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3_smoke.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3_smoke.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp3_smoke.$(ClusterId).log

should_transfer_files = YES
environment           = "MODEL_OUT_DIR=/home/ange00008/projects/mobileFT_distill/data/models/SmolLM3-3B LAMP_DIR=/home/ange00008/projects/mobileFT_distill/data/lamp_time CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0

request_GPUs          = 1
request_CPUs          = 2
request_memory        = 16G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

queue 1
