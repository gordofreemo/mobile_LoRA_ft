# Paired comparison — User-LoRA Round 2 / variant B.
#
# CPU-only job (scipy + rouge_score; no model). Runs eval/paired_compare.py on
# the pre-registered Round-2 variant-B comparisons (see
# experiments/2026-06-16-user-lora-round2-B-plan.md § Step 7).
#
# Pre-registered primary gate (decision 5):
#     passes_registered_gate := (mean_diff > 0) AND (paired_t_p_value < 0.05)
# evaluated on the PRIMARY-TEST comparison only. The other three are reported
# for transparency / secondary description.
#
# Comparisons:
#   Primary, test:    C2 test  vs  C3' test  →  primary gate eval point
#   Primary, dev:     C2 dev   vs  C3' dev   →  transparency (Round-1 parity)
#   Secondary, test:  C3 test  vs  C3' test  →  did variant B beat bare-train?
#   Secondary, dev:   C3 dev   vs  C3' dev   →  transparency
#
# Submit:
#   condor_submit condor/paired_compare_bm25k4.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/paired_compare.py

pred_a   =
pred_b   =
label_a  =
label_b  =
split    =

arguments = --pred-a $(pred_a) --pred-b $(pred_b) --label-a $(label_a) --label-b $(label_b) --task LaMP_4 --split $(split) --seed 0

output                = /home/ange00008/projects/mobileFT_distill/runlogs/paired_compare_bm25k4.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/paired_compare_bm25k4.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/paired_compare_bm25k4.$(ClusterId).log

should_transfer_files = YES
environment           = "PROJECT_ROOT=/home/ange00008/projects/mobileFT_distill CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

# Tiny CPU job; statistics on n=21/25 finish in milliseconds.
request_GPUs          = 0
request_CPUs          = 1
request_memory        = 2G

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

# Four (pred_a, pred_b, label_a, label_b, split) tuples — order: primary test,
# primary dev, secondary test, secondary dev. The first job is the pre-registered
# gate; the others are descriptive.
queue pred_a, pred_b, label_a, label_b, split from (
  /home/ange00008/projects/mobileFT_distill/results/LaMP_4_test_a1_lamp_1ep_seed0_checkpoint-1000_bm25k4_seed0_useru00000011.predictions.jsonl, /home/ange00008/projects/mobileFT_distill/results/LaMP_4_test_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_bm25k4_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, c2_a1lamp_bm25, c3prime_a1lamp_userlora_bm25_round2_B, test
  /home/ange00008/projects/mobileFT_distill/results/LaMP_4_dev_a1_lamp_1ep_seed0_checkpoint-1000_bm25k4_seed0_useru00000011.predictions.jsonl, /home/ange00008/projects/mobileFT_distill/results/LaMP_4_dev_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_bm25k4_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, c2_a1lamp_bm25, c3prime_a1lamp_userlora_bm25_round2_B, dev
  /home/ange00008/projects/mobileFT_distill/results/LaMP_4_test_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, /home/ange00008/projects/mobileFT_distill/results/LaMP_4_test_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_bm25k4_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, c3_round1, c3prime_round2_B, test
  /home/ange00008/projects/mobileFT_distill/results/LaMP_4_dev_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, /home/ange00008/projects/mobileFT_distill/results/LaMP_4_dev_a1_lamp_1ep_seed0_checkpoint-1000_user_lora_lamp4_u00000011_bm25k4_seed0_final_bm25k4_seed0_useru00000011.predictions.jsonl, c3_round1, c3prime_round2_B, dev
)
