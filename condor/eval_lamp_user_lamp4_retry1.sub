# LaMP eval — Round 6 retry for the 18 rows that failed in the first
# condor/eval_lamp_user_lamp4_multi.sub submission (cluster 170364).
#
# Same root cause as condor/train_user_lora_lamp4_retry1.sub: all 18 crashed
# with "RuntimeError: CUDA error: CUDA-capable device(s) is/are busy or
# unavailable" (this time inside transformers' caching_allocator_warmup /
# torch.cuda.mem_get_info, before any model weights loaded), and all 18
# landed on the same execute node (tyr1) — the second time this exact node
# has produced this failure mode for this project. Verified no partial
# output: none of the 18 (adapter, base_adapter, user_fp) rows have a
# results JSON or predictions JSONL on disk, so these are safe to resubmit
# as-is (eval_lamp.py's refuse-to-overwrite means a naive resubmit of the
# full 200 would also work, but this is the minimal retry).
#
# The other 182 rows from the first submission are unaffected — verified
# present (results/*.json + *.predictions.jsonl for each).
#
# Same recipe / hardware / image as condor/eval_lamp_user_lamp4_multi.sub —
# no config changes, this is purely an infra retry.
#
# Submit (after committing this file):
#   condor_submit condor/eval_lamp_user_lamp4_retry1.sub

universe              = docker
docker_image          = ghcr.io/gordofreemo/smollm3-train:ver4
executable            = eval/eval_lamp.py

adapter      = none
base_adapter = none
user_fp      = u00000000

arguments    = --task LaMP_4 --split test --k 4 --seed 0 --adapter $(adapter) --base-adapter $(base_adapter) --user-records $(user_fp)

output                = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry1.$(ClusterId).$(ProcId).out
error                 = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry1.$(ClusterId).$(ProcId).err
log                   = /home/ange00008/projects/mobileFT_distill/runlogs/eval_lamp_user_lamp4_retry1.$(ClusterId).log

should_transfer_files = YES
environment           = "MODEL_OUT_DIR=/home/ange00008/projects/mobileFT_distill/data/models/SmolLM3-3B LAMP_DIR=/home/ange00008/projects/mobileFT_distill/data/lamp_time CONDOR_CLUSTER_ID=$(ClusterId) CONDOR_PROC_ID=$(ProcId)"

max_job_retirement_time = 600
when_to_transfer_output = ON_EXIT_OR_EVICT
stream_output           = true
stream_error            = true

gpus_minimum_memory     = 32000
gpus_minimum_capability = 8.0
# Capability *range*, not just a floor. The cluster has RTX PRO 6000 Blackwell
# (sm_120 / Capability=12.0) nodes that the ver4 Docker image's PyTorch
# (2.5.1+cu124) cannot target -- its kernels stop at sm_90. A bare
# gpus_minimum_capability = 8.0 admits Blackwell and the job dies at the
# first CUDA call with "no kernel image is available for execution on the
# device" (hit for the first time in this project on 2026-07-07, eval
# cluster 170373 procs 1/2/4/6, host fornjoter). Cap at < 10.0 to exclude
# Blackwell while keeping Hopper (9.0), Ada (8.9), and Ampere (8.0+). Pattern
# copied from condor/eval_lamp_llama.sub, which hit this first.
require_gpus            = Capability >= 8.0 && Capability < 10.0

request_GPUs          = 1
request_CPUs          = 2
request_memory        = 16G
requirements          = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted   = true
+WantScratchMounted   = true

